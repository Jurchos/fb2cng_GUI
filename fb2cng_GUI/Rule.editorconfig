ini
# Застосовувати правила до всіх файлів у проєкті
[*]
# Встановлює кодування UTF-8
charset = utf-8

# Примусово встановлює перенесення рядків Windows (CRLF)
end_of_line = crlf

# Автоматично видаляє зайві пробіли в кінці рядків
trim_trailing_whitespace = true

# Додає порожній рядок в кінці файлу (стандарт чистого коду)
insert_final_newline = true