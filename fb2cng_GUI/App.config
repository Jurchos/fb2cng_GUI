<?xml version="1.0" encoding="utf-8" ?>
<configuration>
	<configSections>
		<!-- ЦЕЙ РЯДОК ПРАВИЛЬНО РЕЄСТРУЄ СЕКЦІЮ DPI ДЛЯ WINDOWS FORMS -->
		<sectionGroup name="System.Windows.Forms.ApplicationConfigurationSection" type="System.Windows.Forms.ApplicationConfigurationSection, System.Windows.Forms, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
			<section name="DpiAwareness" type="System.Configuration.NameValueSectionHandler, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" />
		</sectionGroup>
	</configSections>

	<startup>
		<supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
	</startup>

	<!-- БЛОК НАЛАШТУВАННЯ ЧІТКОСТІ ШРИФТІВ НА WINDOWS 10 ТА WINDOWS 11 -->
	<System.Windows.Forms.ApplicationConfigurationSection>
		<add key="DpiAwareness" value="PerMonitorV2" />
		<add key="EnableWindowsFormsHighDpiAutoResizing" value="true" />
	</System.Windows.Forms.ApplicationConfigurationSection>
</configuration>
